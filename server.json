{
  "name": "io.github.samik081/mcp-authentik",
  "version": "0.4.0",
  "title": "Authentik MCP Server",
  "description": "MCP server for Authentik identity management",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Samik081/mcp-authentik.git"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@samik081/mcp-authentik",
      "version": "0.4.0",
      "runtimeHint": "node",
      "environment_variables": [
        {
          "name": "AUTHENTIK_URL",
          "description": "URL of the Authentik instance (e.g. https://auth.example.com)",
          "required": true
        },
        {
          "name": "AUTHENTIK_TOKEN",
          "description": "Authentik API token",
          "required": true,
          "secret": true
        }
      ]
    },
    {
      "registryType": "oci",
      "identifier": "ghcr.io/samik081/mcp-authentik:0.4.0",
      "version": "0.4.0",
      "runtimeHint": "docker",
      "environment_variables": [
        {
          "name": "AUTHENTIK_URL",
          "description": "URL of the Authentik instance (e.g. https://auth.example.com)",
          "required": true
        },
        {
          "name": "AUTHENTIK_TOKEN",
          "description": "Authentik API token",
          "required": true,
          "secret": true
        }
      ]
    }
  ]
}
