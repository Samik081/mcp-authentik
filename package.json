{
  "name": "@samik081/mcp-authentik",
  "mcpName": "io.github.Samik081/mcp-authentik",
  "version": "0.5.0",
  "description": "Manage Authentik through AI assistants",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mcp-authentik": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "test": "vitest run",
    "start": "node dist/index.js",
    "dev": "node --watch --experimental-strip-types src/index.ts",
    "inspect": "npm run build && npx @modelcontextprotocol/inspector node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "authentik",
    "identity",
    "sso",
    "iam",
    "ai",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Samik081/mcp-authentik.git"
  },
  "homepage": "https://github.com/Samik081/mcp-authentik#readme",
  "bugs": {
    "url": "https://github.com/Samik081/mcp-authentik/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@goauthentik/api": "2025.6.3-1751754396",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^22.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
